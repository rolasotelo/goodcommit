{
  "api_version": "goodcommit.io/v1",
  "kind": "Plugin",
  "id": "builtin/description",
  "name": "Description",
  "version": "1.0.0",
  "protocol_versions": ["1.0"],
  "entrypoint": {
    "type": "exec",
    "command": "go",
    "args": ["run", "./cmd/goodcommit-plugin-description"]
  },
  "hooks": ["collect"],
  "permissions": { "network": false, "git_read": false, "git_write": false },
  "contract": {
    "answers": [
      {
        "key": "commit_description",
        "description": "Short summary phrase.",
        "type": "string",
        "required": true,
        "strategy": "infer_from_diff"
      }
    ],
    "metadata_writes": [
      { "key": "gc.description", "description": "Normalized description text." }
    ]
  },
  "ai_hints": {
    "purpose": "Capture concise commit summary text.",
    "instructions": "Fill commit_description with one short, lower-case sentence fragment (<=72 chars)."
  }
}
