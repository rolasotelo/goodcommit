{
  "plugins": [
    {
      "id": "builtin/types",
      "enabled": true,
      "ai_constraints": {
        "commit_type": {
          "allowed_values_from_json": {
            "path": "./commit-types.json",
            "array_key": "types",
            "value_key": "id"
          }
        }
      },
      "order": 1,
      "failure_mode": "fail_closed",
      "timeout_ms": 10000,
      "config": { "path": "./configs/commit-types.json" }
    },
    {
      "id": "builtin/description",
      "enabled": true,
      "ui_group": "compose_message",
      "order": 30,
      "failure_mode": "fail_closed",
      "timeout_ms": 10000,
      "config": {}
    },
    {
      "id": "builtin/body",
      "enabled": true,
      "ui_group": "compose_message",
      "order": 50,
      "failure_mode": "fail_open",
      "timeout_ms": 10000,
      "config": {}
    },
    {
      "id": "builtin/conventional-title",
      "enabled": true,
      "order": 90,
      "failure_mode": "fail_closed",
      "timeout_ms": 10000,
      "config": {}
    }
  ]
}
