{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rolasotelo/goodcommit/blob/main/schemas/gcpp-request.schema.json",
  "title": "Goodcommit Plugin Request v1",
  "type": "object",
  "required": [
    "protocol_version",
    "request_id",
    "plugin_id",
    "hook",
    "context",
    "draft"
  ],
  "properties": {
    "protocol_version": { "type": "string", "const": "1.0" },
    "request_id": { "type": "string", "minLength": 1 },
    "plugin_id": { "type": "string", "minLength": 1 },
    "hook": {
      "type": "string",
      "enum": [
        "collect",
        "validate",
        "enrich",
        "finalize",
        "pre_commit",
        "post_commit"
      ]
    },
    "plugin_config": {
      "type": "object",
      "additionalProperties": true
    },
    "context": {
      "type": "object",
      "required": ["repo_root", "staged_files"],
      "properties": {
        "repo_root": { "type": "string" },
        "branch": { "type": "string" },
        "head": { "type": "string" },
        "staged_files": {
          "type": "array",
          "items": { "type": "string" }
        },
        "git_user_name": { "type": "string" },
        "git_user_email": { "type": "string" },
        "timestamp_utc": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": true
    },
    "draft": {
      "type": "object",
      "required": ["title", "body", "trailers", "metadata"],
      "properties": {
        "title": { "type": "string" },
        "body": { "type": "string" },
        "trailers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["key", "value"],
            "properties": {
              "key": { "type": "string" },
              "value": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "answers": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
